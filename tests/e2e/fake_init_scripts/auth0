#!/usr/bin/env python3
"""Fake auth0 CLI for e2e init tests.

Handles the subcommands used by `tv-proxy init`:
  - apps update <id> --callbacks <urls> --logout-urls <urls>
  - apps show <id> --reveal-secrets --json
  - tenants list --json
"""
import json
import sys

args = sys.argv[1:]

# --- apps update ---
if len(args) >= 2 and args[0] == "apps" and args[1] == "update":
    print("Application updated successfully", file=sys.stderr)
    sys.exit(0)

# --- apps show ---
if len(args) >= 2 and args[0] == "apps" and args[1] == "show":
    if "--json" in args:
        print(json.dumps({
            "client_id": "test-client-id",
            "client_secret": "test-client-secret",
            "name": "Token Vault Test App",
        }))
    else:
        print("=== Token Vault Test App ===")
        print("Client ID:      test-client-id")
        print("Client Secret:  test-client-secret")
    sys.exit(0)

# --- tenants list ---
if len(args) >= 2 and args[0] == "tenants" and args[1] == "list":
    if "--json" in args:
        print(json.dumps([{"name": "test.auth0.com"}]))
    else:
        print("test.auth0.com")
    sys.exit(0)

print(f"Fake auth0: unhandled command: {' '.join(args)}", file=sys.stderr)
sys.exit(1)
